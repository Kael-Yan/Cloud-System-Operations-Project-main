<script>
    $(document).ready(function() {
        // 檢查cookie設置黑暗模式
        function checkDarkMode() {
            if (document.cookie.split(';').some((item) => item.trim().startsWith('darkMode='))) {
                var darkMode = document.cookie.replace(/(?:(?:^|.*;\s*)darkMode\s*\=\s*([^;]*).*$)|^.*$/, "$1") === 'true';
                if (darkMode) {
                    $('body').addClass('dark-mode');
                    $('#darkModeText, #sidebarDarkModeText').text('明亮模式');
                } else {
                    $('body').removeClass('dark-mode');
                    $('#darkModeText, #sidebarDarkModeText').text('黑暗模式');
                }
            }
        }

        // 初始化檢查
        checkDarkMode();

        // 黑暗模式切換 - 處理兩個按鈕
        $('#darkModeToggle, #sidebarDarkModeToggle').click(function(e) {
            e.preventDefault();
            $('body').toggleClass('dark-mode');
            
            var isDarkMode = $('body').hasClass('dark-mode');
            if (isDarkMode) {
                $('#darkModeText, #sidebarDarkModeText').text('明亮模式');
            } else {
                $('#darkModeText, #sidebarDarkModeText').text('黑暗模式');
            }
            
            // 設置cookie，有效期30天
            var date = new Date();
            date.setTime(date.getTime() + (30 * 24 * 60 * 60 * 1000));
            document.cookie = `darkMode=${isDarkMode}; expires=${date.toUTCString()}; path=/`;
        });

        // 桌面版側邊欄收放功能
        $('#desktopSidebarToggle').click(function(e) {
            e.preventDefault();
            $('#sidebarContainer').toggleClass('collapsed');
        });
        
        // 移動設備側邊欄切換
        $('.navbar-toggle').click(function(e) {
            e.stopPropagation(); // 防止事件冒泡
            $('#sidebarContainer').toggleClass('show');
        });
        
        // 點擊主內容區關閉移動端側邊欄
        $('.main-content').click(function() {
            if ($(window).width() <= 768 && $('#sidebarContainer').hasClass('show')) {
                $('#sidebarContainer').removeClass('show');
            }
        });
        
        // 設置 moment.js 為中文
        moment.locale('zh-tw', {
            relativeTime: {
                future: '%s內',
                past: '%s前',
                s: '幾秒',
                m: '1分鐘',
                mm: '%d分鐘',
                h: '1小時',
                hh: '%d小時',
                d: '1天',
                dd: '%d天',
                M: '1個月',
                MM: '%d個月',
                y: '1年',
                yy: '%d年'
            },
            months: '一月_二月_三月_四月_五月_六月_七月_八月_九月_十月_十一月_十二月'.split('_'),
            monthsShort: '1月_2月_3月_4月_5月_6月_7月_8月_9月_10月_11月_12月'.split('_'),
            weekdays: '星期日_星期一_星期二_星期三_星期四_星期五_星期六'.split('_'),
            weekdaysShort: '週日_週一_週二_週三_週四_週五_週六'.split('_'),
            weekdaysMin: '日_一_二_三_四_五_六'.split('_')
        });
    });
    
    // 處理窗口大小變化
    $(window).resize(function() {
        if ($(window).width() > 768) {
            $('#sidebarContainer').removeClass('show');
        }
    });

    // 封鎖內容切換功能
    function toggleBlockedContent(element) {
        const content = element.parentElement.querySelector('.blocked-body');
        const chevron = element.querySelector('.glyphicon-chevron-down');
        
        if (content.style.display === 'none') {
            content.style.display = 'block';
            chevron.classList.remove('glyphicon-chevron-down');
            chevron.classList.add('glyphicon-chevron-up');
        } else {
            content.style.display = 'none';
            chevron.classList.remove('glyphicon-chevron-up');
            chevron.classList.add('glyphicon-chevron-down');
        }
    }
</script>
