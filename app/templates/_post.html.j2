<table class="table table-hover">
    <tr>
        <td width="70px">
            <a href="{{ url_for('user', username=post.user.username) }}">
                <img src="{{ post.user.avatar(70) }}"/>
            </a>
        </td>
        <td>
            {% set user_link %}
            <a href="{{ url_for('user', username=post.user.username) }}">{{ post.user.username }}</a>
        {% endset %}
        {{ _('%(username)s said', username=user_link) }}
        <span class="moment-time" data-timestamp="{{ post.timestamp }}"></span>
        <br/>
        {{ post.body }}
    </td>
</tr>
</table>
