{% extends "base.html.j2" %}
{% import 'bootstrap/wtf.html' as wtf %}

{% block styles %}
{{ super() }}
<style>


    .register-modal {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: white;
        padding: 0;
        border-radius: 8px;
        box-shadow: 0 0 20px rgba(0,0,0,0.3);
        z-index: 1001;
        width: 800px;
        max-width: 90%;
        max-height: 90vh; /* 新增 */
        overflow-y: auto; /* 新增 */
        display: none;
    }
    
    .register-content {
        padding: 25px 100px;
        max-height: calc(90vh - 60px); /* 新增 */
        overflow-y: auto; /* 新增 */
    }

    /* 響應式調整 */
    @media (max-height: 700px) {
        .register-content {
            padding: 15px 50px;
        }
    }
    
    @media (max-height: 500px) {
        .register-content {
            padding: 10px 30px;
        }
        
        .form-group {
            margin-bottom: 10px;
        }
    }



    /* 添加黑暗模式樣式 */
    body.dark-mode .register-modal {
        background-color: #2d2d2d;
        color: #e0e0e0;
    }

    body.dark-mode .register-content {
        background-color: #2d2d2d;
    }

    body.dark-mode .form-control {
        background-color: #444;
        color: #e0e0e0;
        border-color: #555;
    }

    body.dark-mode .form-control:focus {
        background-color: #555;
        color: #e0e0e0;
    }

    body.dark-mode .btn-hk-golden {
        background-color: #3a5f8a;
        border-color: #3a5f8a;
    }

    body.dark-mode .btn-hk-golden:hover {
        background-color: #4a6f9a;
        border-color: #4a6f9a;
    }

    body.dark-mode a {
        color: #5a8fd3;
    }

    body.dark-mode .gender-option label {
        color: #e0e0e0;
    }



    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0,0,0,0.7);
        z-index: 1000;
        display: none;
    }
    
    .register-modal {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: white;
        padding: 0;
        border-radius: 8px;
        box-shadow: 0 0 20px rgba(0,0,0,0.3);
        z-index: 1001;
        width: 800px;
        max-width: 90%;
        display: none;
        overflow: hidden;
    }
    
    .register-header-bar {
        height: 60px;
        width: 100%;
        background: linear-gradient(90deg, #346599);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }
    
    .register-header-bar h2 {
        color: white;
        margin: 0;
        font-weight: bold;
        font-size: 20px;
        text-shadow: 0 1px 2px rgba(0,0,0,0.2);
    }
    
    .register-content {
        padding: 25px 100px;
    }
    
    .form-container {
        padding: 30px;
    }
    
    /* 性别选择样式 */
    .gender-options {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
    }
    
    .gender-option {
        display: flex;
        align-items: center;
    }
    
    .gender-option input[type="radio"] {
        width: 18px;
        height: 18px;
        margin-right: 8px;
    }
    
    .gender-option label {
        margin-bottom: 0;
    }
    
    .btn-hk-golden {
        background-color: #346599;
        border-color: #346599;
        color: white;
        font-weight: bold;
        padding: 12px 30px;
        font-size: 16px;
        width: 60%;
        margin: 20px auto 0;
        display: block;
        border-radius: 4px;
        transition: all 0.3s;
    }
    
    .btn-hk-golden:hover {
        background-color: #24466b;
        border-color: #24466b;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    
    .form-group {
        margin-bottom: 20px;
    }
    
    .form-control {
        height: 45px;
        border-radius: 4px;
        border: 1px solid #ddd;
        padding: 10px 15px;
        font-size: 15px;
        width: 100%;
    }
    
    .close-btn {
        position: absolute;
        top: 5px;
        right: 15px;
        font-size: 30px;
        cursor: pointer;
        color: white;
        z-index: 2;
        text-shadow: 0 1px 2px rgba(0,0,0,0.2);
    }
    
    .close-btn:hover {
        color: #ffcc00;
    }
    
    .is-invalid {
        border-color: #dc3545;
    }

    .invalid-feedback {
        display: none;
        color: #dc3545;
        font-size: 14px;
        margin-top: 5px;
    }

    .is-invalid ~ .invalid-feedback {
        display: block;
    }

    /* 禁用按鈕樣式 */
    button:disabled {
        opacity: 0.65;
        cursor: not-allowed;
    }
        .is-valid {
        border-color: #28a745 !important;
    }

    .username-feedback {
        font-size: 14px;
        margin-top: 5px;
    }

    button[type="submit"]:disabled {
        opacity: 0.65;
        cursor: not-allowed;
        background-color: #6c757d !important;
        border-color: #6c757d !important;
    }
</style>
{% endblock %}

{% block content %}

<div class="modal-overlay" id="registerOverlay"></div>

<div class="register-modal" id="registerModal">
    <div class="register-header-bar">
        <h2><span class="glyphicon glyphicon-edit"></span> 會員註冊</h2>
        <span class="close-btn" id="closeRegister">&times;</span>
    </div>
    
    <div class="register-content">
        <form method="POST" class="form-horizontal">
            {{ form.hidden_tag() }}
            
            <div class="form-group">
                {{ form.username.label(class="control-label") }}
                {{ form.username(class="form-control", placeholder="輸入用戶名") }}
                <div class="invalid-feedback">
                    {% for error in form.username.errors %}
                        <div style="display: block;">{{ error }}</div>
                    {% endfor %}
                    <div class="username-feedback" style="display: block;"></div>
                </div>
            </div>
            
            <div class="form-group">
                {{ form.email.label(class="control-label") }}
                {{ form.email(class="form-control", placeholder="輸入電子郵件") }}
                {% for error in form.email.errors %}
                    <div class="invalid-feedback" style="display: block;">{{ error }}</div>
                {% endfor %}
            </div>
            
            <div class="form-group">
                {{ form.phone.label(class="control-label") }}
                {{ form.phone(class="form-control", placeholder="輸入電話號碼") }}
                {% for error in form.phone.errors %}
                    <div class="invalid-feedback" style="display: block;">{{ error }}</div>
                {% endfor %}
            </div>
            
            <div class="form-group">
                <label class="control-label">性別</label>
                <div class="gender-options">
                    <div class="gender-option">
                        <input type="radio" id="male" name="gender" value="male" required>
                        <label for="male">男</label>
                    </div>
                    <div class="gender-option">
                        <input type="radio" id="female" name="gender" value="female">
                        <label for="female">女</label>
                    </div>
                </div>
            </div>
            
            <div class="form-group">
                <label for="password" class="control-label">密碼</label>
                <input type="password" id="password" name="password" class="form-control" 
                        placeholder="輸入密碼" required
                        minlength="8" title="密碼長度至少8個字符">
                <div class="invalid-feedback">密碼長度至少8個字符</div>
            </div>
            <div class="form-group">
                <label for="password2" class="control-label">確認密碼</label>
                <input type="password" id="password2" name="password2" class="form-control" 
                        placeholder="再次輸入密碼" required
                        title="兩次輸入的密碼必須一致"
                        data-match="#password" data-match-error="密碼不一致">
                <div class="invalid-feedback">兩次輸入的密碼必須一致</div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-hk-golden">註冊</button>
            </div>
        </form>
        
        <div style="text-align: center; margin-top: 25px;">
            <p style="font-size: 14px;">
                已經有帳號？
                <a href="{{ url_for('login') }}" style="color: #346599; text-decoration: underline;">
                    立即登入
                </a>
            </p>
        </div>
    </div>
</div>

<div id="mainContent">
    {{ super() }}
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const password = document.getElementById('password');
    const password2 = document.getElementById('password2');
    const usernameInput = document.querySelector('input[name="username"]');
    const form = document.querySelector('form');
    let usernameCheckTimeout = null;
    let isUsernameAvailable = false;

    // 檢查用戶名是否可用
    function checkUsernameAvailability(username) {
        if (username.length < 3) {
            return; // 用戶名太短不檢查
        }

        fetch(`/api/check_username?username=${encodeURIComponent(username)}`)
            .then(response => response.json())
            .then(data => {
                const feedbackElement = usernameInput.nextElementSibling.querySelector('.username-feedback');
                if (data.available) {
                    usernameInput.classList.remove('is-invalid');
                    usernameInput.classList.add('is-valid');
                    feedbackElement.textContent = '用戶名可用';
                    feedbackElement.style.color = 'green';
                    isUsernameAvailable = true;
                } else {
                    usernameInput.classList.remove('is-valid');
                    usernameInput.classList.add('is-invalid');
                    feedbackElement.textContent = '該用戶名已被使用';
                    feedbackElement.style.color = 'red';
                    isUsernameAvailable = false;
                }
                updateSubmitButtonState();
            })
            .catch(error => {
                console.error('檢查用戶名時出錯:', error);
            });
    }

    // 更新提交按鈕狀態
    function updateSubmitButtonState() {
        const passwordValid = validatePasswordLength();
        const passwordsMatch = validatePasswordMatch();
        submitBtn.disabled = !(isUsernameAvailable && passwordValid && passwordsMatch);
    }

    // 用戶名輸入事件處理
    usernameInput.addEventListener('input', function() {
        clearTimeout(usernameCheckTimeout);
        const feedbackElement = this.nextElementSibling.querySelector('.username-feedback');
        
        if (this.value.length < 3) {
            this.classList.remove('is-valid', 'is-invalid');
            feedbackElement.textContent = '';
            isUsernameAvailable = false;
            updateSubmitButtonState();
            return;
        }

        usernameCheckTimeout = setTimeout(() => {
            checkUsernameAvailability(this.value);
        }, 500); // 防抖處理，500毫秒後檢查
    });

    // 密碼驗證函數
    function validatePasswordLength() {
        if (password.value.length < 8) {
            password.classList.add('is-invalid');
            return false;
        } else {
            password.classList.remove('is-invalid');
            return true;
        }
    }

    function validatePasswordMatch() {
        if (password2.value !== password.value) {
            password2.classList.add('is-invalid');
            return false;
        } else {
            password2.classList.remove('is-invalid');
            return true;
        }
    }

    // 密碼輸入事件處理
    password.addEventListener('input', function() {
        validatePasswordLength();
        if (password2.value.length > 0) {
            validatePasswordMatch();
        }
        updateSubmitButtonState();
    });

    password2.addEventListener('input', function() {
        validatePasswordMatch();
        updateSubmitButtonState();
    });

    // 表單提交驗證
    form.addEventListener('submit', function(event) {
        if (!validatePasswordLength() || !validatePasswordMatch() || !isUsernameAvailable) {
            event.preventDefault();
        }
    });
    
    // 初始禁用提交按鈕
    const submitBtn = document.querySelector('button[type="submit"]');
    if (submitBtn) {
        submitBtn.disabled = true;
        
        // 監聽輸入變化啟用/禁用按鈕
        form.addEventListener('input', function() {
            updateSubmitButtonState();
        });
    }

    // 模態框相關代碼保持不變
    $(document).ready(function() {
        // Show register modal
        function showRegisterModal() {
            $('#registerOverlay').fadeIn(200);
            $('#registerModal').fadeIn(300);
            $('body').css('overflow', 'hidden');
        }
        
        // Hide register modal and redirect to 吹水台
        function hideRegisterModal() {
            $('#registerOverlay').fadeOut(200);
            $('#registerModal').fadeOut(300, function() {
                window.location.href = "{{ url_for('category', category='吹水台') }}";
            });
            $('body').css('overflow', 'auto');
        }
        
        // Handle register link clicks
        $('a[href="{{ url_for('register') }}"]').click(function(e) {
            e.preventDefault();
            showRegisterModal();
        });
        
        // Handle close button click
        $('#closeRegister').click(hideRegisterModal);
        
        // Handle overlay click
        $('#registerOverlay').click(hideRegisterModal);
        
        // Handle ESC key press
        $(document).keyup(function(e) {
            if (e.key === "Escape") {
                hideRegisterModal();
            }
        });
        
        // Show modal if directly accessing register page
        {% if request.path == url_for('register') %}
        showRegisterModal();
        {% endif %}
    });
});
</script>
{% endblock %}