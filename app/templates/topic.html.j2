{% extends "base.html.j2" %}

{% block styles %}
{{ super() }}
<style>

    /* 添加黑暗模式樣式 */
    body.dark-mode .panel-default {
        background-color: #2d2d2d;
        border-color: #444;
    }

    body.dark-mode .panel-heading {
        background-color: #333;
        border-color: #444;
        color: #e0e0e0;
    }

    body.dark-mode .panel-body {
        background-color: #2d2d2d;
        color: #e0e0e0;
    }

    body.dark-mode .alert-info {
        background-color: #1a3e5a;
        border-color: #2a4e6a;
        color: #e0e0e0;
    }

    body.dark-mode .btn-default {
        background-color: #444;
        color: #e0e0e0;
        border-color: #555;
    }

    body.dark-mode .btn-default:hover {
        background-color: #555;
    }

    body.dark-mode .btn-primary {
        background-color: #3a5f8a;
        border-color: #3a5f8a;
    }

    body.dark-mode .btn-primary:hover {
        background-color: #4a6f9a;
        border-color: #4a6f9a;
    }

    body.dark-mode .form-control {
        background-color: #444;
        color: #e0e0e0;
        border-color: #555;
    }

    body.dark-mode .form-control:focus {
        background-color: #555;
        color: #e0e0e0;
    }
    body.dark-mode .panel-default {
        background-color: #2d2d2d;
        border-color: #444;
    }

    body.dark-mode .panel-heading {
        background-color: #333;
        border-color: #444;
        color: #e0e0e0;
    }

    body.dark-mode .panel-body {
        background-color: #2d2d2d;
        color: #e0e0e0;
    }

    body.dark-mode .alert-info {
        background-color: #1a3e5a;
        border-color: #2a4e6a;
        color: #e0e0e0;
    }

    body.dark-mode .btn-default {
        background-color: #444;
        color: #e0e0e0;
        border-color: #555;
    }

    body.dark-mode .btn-default:hover {
        background-color: #555;
    }

    body.dark-mode .btn-primary {
        background-color: #3a5f8a;
        border-color: #3a5f8a;
    }

    body.dark-mode .btn-primary:hover {
        background-color: #4a6f9a;
        border-color: #4a6f9a;
    }

    body.dark-mode .form-control {
        background-color: #444;
        color: #e0e0e0;
        border-color: #555;
    }

    body.dark-mode .form-control:focus {
        background-color: #555;
        color: #e0e0e0;
    }

    /* Blocked content styles */
    .blocked-header {
        background-color: #f8f8f8;
        border-bottom: 1px solid #ddd;
        padding: 10px 15px;
        cursor: pointer;
    }

    .blocked-header:hover {
        background-color: #f0f0f0;
    }

    .blocked-content .panel-body {
        padding: 0;
    }

    

    body.dark-mode .blocked-header {
        background-color: #333;
        border-color: #444;
    }

    body.dark-mode .blocked-header:hover {
        background-color: #3a3a3a;
    }
</style>
{% endblock %}

{% block app_content %}
<div class="container">
    <div class="row">
        <div class="col-md-8">
            <!-- Topic Display -->
            <div><a style="font-size: medium;" href="{{ url_for('category', category= topic.category) }}"><span class="glyphicon glyphicon-chevron-left"></span>{{ topic.category }}</a></div>
            <div class="panel panel-default {% if current_user.is_authenticated and current_user.is_blocking(topic.author) %}blocked-content{% endif %}">
                {% if current_user.is_authenticated and current_user.is_blocking(topic.author) %}
                <div class="blocked-header" onclick="toggleBlockedContent(this)">
                    <span class="text-muted">已封鎖的用戶內容 ({{ topic.author.username }})</span>
                    <span class="glyphicon glyphicon-chevron-down pull-right"></span>
                </div>
                <div class="blocked-body" style="display: none;">
                {% endif %}
                
                <div class="panel-heading">
                    <h2>{{ topic.title }}</h2>
                    <small>
                        <span class="glyphicon glyphicon-user"></span> 
                        <a href="{{ url_for('user', username=topic.author.username) }}" 
                            class="username {% if topic.author.gender == 'male' %}male{% elif topic.author.gender == 'female' %}female{% endif %}">
                            {{ topic.author.username }}
                        </a>
                        <span class="glyphicon glyphicon-time" style="margin-left: 10px;"></span> 
                        <span class="moment-time" data-timestamp="{{ topic.timestamp }}"></span>
                        {% if not topic.is_public %}
                            <span class="label label-warning" style="margin-left: 10px;">私人Topic</span>
                        {% endif %}
                    </small>
                </div>
                <div class="panel-body">
                    <p>{{ topic.body }}</p>
                    {% if topic.image %}
                    <img src="{{ topic.image }}" class="img-responsive" style="max-height: 300px; margin-bottom: 15px;">
                    {% endif %}

                    <div class="btn-group" role="group">
                        {% if current_user.is_authenticated %}
                            {% if topic.id in bookmarked_ids %}
                                <a href="{{ url_for('unbookmark', post_id=topic.id) }}" class="btn btn-default btn-sm">
                                    <span class="glyphicon glyphicon-bookmark text-danger"></span> 取消留名
                                </a>
                            {% else %}
                                <a href="{{ url_for('bookmark', post_id=topic.id) }}" class="btn btn-default btn-sm">
                                    <span class="glyphicon glyphicon-bookmark"></span> 留名
                                </a>
                            {% endif %}
                            
                            {% set user_vote = current_user.get_vote_type(topic) if current_user.is_authenticated else None %}
                            
                            <form method="POST" action="{{ url_for('vote', post_id=topic.id, vote_type='like') }}" style="display: inline;">
                                {{ vote_form.hidden_tag() }}
                                <button type="submit" class="btn btn-default btn-sm{% if user_vote == 'like' %} active{% endif %}">
                                    <span class="glyphicon glyphicon-thumbs-up"></span> 好評 {{ topic.likes }}
                                </button>
                            </form>
                            
                            <form method="POST" action="{{ url_for('vote', post_id=topic.id, vote_type='dislike') }}" style="display: inline;">
                                {{ vote_form.hidden_tag() }}
                                <button type="submit" class="btn btn-default btn-sm{% if user_vote == 'dislike' %} active{% endif %}">
                                    <span class="glyphicon glyphicon-thumbs-down"></span> 差評 {{ topic.dislikes }}
                                </button>
                            </form>
                        {% else %}
                            <button class="btn btn-default btn-sm" disabled>
                                <span class="glyphicon glyphicon-thumbs-up"></span> 好評 {{ topic.likes }}
                            </button>
                            <button class="btn btn-default btn-sm" disabled>
                                <span class="glyphicon glyphicon-thumbs-down"></span> 差評 {{ topic.dislikes }}
                            </button>
                        {% endif %}
                    </div>
                </div>
                
                {% if current_user.is_authenticated and current_user.is_blocking(topic.author) %}
                </div>
                {% endif %}
            </div>

            <!-- Replies List -->
            <h3>回覆列表</h3>
            {% if replies %}
                {% for reply in replies %}
                <div class="panel panel-default {% if current_user.is_authenticated and current_user.is_blocking(reply.author) %}blocked-content{% endif %}" style="margin-left: 30px;">
                    {% if current_user.is_authenticated and current_user.is_blocking(reply.author) %}
                    <div class="blocked-header" onclick="toggleBlockedContent(this)">
                        <span class="text-muted">已封鎖的用戶回覆 ({{ reply.authorr.username }})</span>
                        <span class="glyphicon glyphicon-chevron-down pull-right"></span>
                    </div>
                    <div class="blocked-body" style="display: none;">
                    {% endif %}
                    
                    <div class="panel-heading">
                        <small>
                            <span class="glyphicon glyphicon-user"></span> 
                            <a href="{{ url_for('user', username=reply.author.username) }}" style="color: #d9534f;">
                                {{ reply.author.username }}
                            </a>
                            <span class="glyphicon glyphicon-time" style="margin-left: 10px;"></span> 
                            <span class="moment-time" data-timestamp="{{ reply.timestamp }}"></span>
                        </small>
                    </div>
                    <div class="panel-body">
                        <p>{{ reply.body }}</p>
                        {% if reply.image %}
                        <img src="{{ reply.image }}" class="img-responsive" style="max-height: 200px; margin-bottom: 10px;">
                        {% endif %}
                        
                        <div class="btn-group" role="group">
                            {% if current_user.is_authenticated %}
                                {% set user_vote = current_user.get_vote_type(reply) %}
                                
                                <form method="POST" action="{{ url_for('vote', post_id=reply.id, vote_type='like') }}" style="display: inline;">
                                    {{ vote_form.hidden_tag() }}
                                    <button type="submit" class="btn btn-default btn-xs{% if user_vote == 'like' %} active{% endif %}">
                                        <span class="glyphicon glyphicon-thumbs-up"></span> 好評 {{ reply.likes }}
                                    </button>
                                </form>
                                
                                <form method="POST" action="{{ url_for('vote', post_id=reply.id, vote_type='dislike') }}" style="display: inline;">
                                    {{ vote_form.hidden_tag() }}
                                    <button type="submit" class="btn btn-default btn-xs{% if user_vote == 'dislike' %} active{% endif %}">
                                        <span class="glyphicon glyphicon-thumbs-down"></span> 差評 {{ reply.dislikes }}
                                    </button>
                                </form>
                            {% else %}
                                <button class="btn btn-default btn-xs" disabled>
                                    <span class="glyphicon glyphicon-thumbs-up"></span> 好評 {{ reply.likes }}
                                </button>
                                <button class="btn btn-default btn-xs" disabled>
                                    <span class="glyphicon glyphicon-thumbs-down"></span> 差評 {{ reply.dislikes }}
                                </button>
                            {% endif %}
                        </div>
                    </div>
                    
                    {% if current_user.is_authenticated and current_user.is_blocking(reply.author) %}
                    </div>
                    {% endif %}
                </div>
                {% endfor %}
            {% else %}
                <div class="alert alert-info">
                    目前沒有回覆
                </div>
            {% endif %}

            <!-- Reply Form (now placed below replies) -->
            {% if current_user.is_authenticated %}
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4>發表回覆</h4>
                    </div>
                    <div class="panel-body">
                        <form method="POST" enctype="multipart/form-data" id="replyForm">
                            {{ form.hidden_tag() }}
                            <div class="form-group">
                                {{ form.body(class="form-control", rows=3, placeholder="輸入回覆內容") }}
                                {% for error in form.body.errors %}
                                <span class="text-danger">{{ error }}</span>
                                {% endfor %}
                            </div>
                            <div class="form-group">
                                {{ form.image.label() }}
                                {{ form.image(class="form-control-file", id="replyImage") }}
                                {% if form.image.errors %}
                                    {% for error in form.image.errors %}
                                        <span class="text-danger">{{ error }}</span><br>
                                    {% endfor %}
                                {% endif %}
                                <div id="imageSizeError" class="text-danger" style="display: none;"></div>
                            </div>
                            {{ form.submit(class="btn btn-primary", id="submitReply") }}
                        </form>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script>
    $(document).ready(function() {
        const MAX_FILE_SIZE = 2 * 1024 * 1024; // 2MB in bytes
        const replyForm = document.getElementById('replyForm');
        const replyImage = document.getElementById('replyImage');
        const submitBtn = document.getElementById('submitReply');
        const sizeError = document.getElementById('imageSizeError');

        if (replyImage) {
            replyImage.addEventListener('change', function() {
                if (this.files && this.files[0]) {
                    const fileSize = this.files[0].size;
                    if (fileSize > MAX_FILE_SIZE) {
                        sizeError.textContent = '圖片大小不能超過2MB';
                        sizeError.style.display = 'block';
                        submitBtn.disabled = true;
                    } else {
                        sizeError.style.display = 'none';
                        submitBtn.disabled = false;
                    }
                }
            });

            replyForm.addEventListener('submit', function(e) {
                if (replyImage.files && replyImage.files[0] && 
                    replyImage.files[0].size > MAX_FILE_SIZE) {
                    e.preventDefault();
                    sizeError.textContent = '圖片大小不能超過2MB';
                    sizeError.style.display = 'block';
                }
            });
        }
    });

    function toggleBlockedContent(element) {
        const content = element.parentElement.querySelector('.blocked-body');
        const chevron = element.querySelector('.glyphicon-chevron-down');
        
        if (content.style.display === 'none') {
            content.style.display = 'block';
            chevron.classList.remove('glyphicon-chevron-down');
            chevron.classList.add('glyphicon-chevron-up');
        } else {
            content.style.display = 'none';
            chevron.classList.remove('glyphicon-chevron-up');
            chevron.classList.add('glyphicon-chevron-down');
        }
    }
</script>
{% endblock %}
